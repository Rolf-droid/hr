# URLs sin .html (Apache — hosting compartido GoDaddy)
# Si el sitio está en una subcarpeta, ajusta RewriteBase, por ejemplo:
# RewriteBase /mi-carpeta/

Options -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Canonical: /index.html → /
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ / [R=301,L]

  # Canonical: /ruta/pagina.html → /ruta/pagina
  RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L,NE]

  # Archivos y carpetas reales (assets, partials, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # /pagina → pagina.html si existe
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>
